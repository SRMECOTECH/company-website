# =====================================================
# SMTP — Nodemailer transport
# Works with Gmail App Passwords, Zoho, Brevo, SendGrid SMTP, etc.
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@srmecotech.com
SMTP_PASS=your-app-password-here

# From / To
MAIL_FROM="SRM ECO TECH <info@srmecotech.com>"
MAIL_TO_CONTACT=info@srmecotech.com

# Admin key required to broadcast newsletters
ADMIN_KEY=replace-with-a-long-random-string

# CORS — comma-separated list of allowed origins for the frontend.
# Examples:
#   CORS_ORIGINS=http://localhost:5173,https://www.srmecotech.com
CORS_ORIGINS=http://localhost:5173

# Site URL (used inside email templates)
SITE_URL=https://www.srmecotech.com

# Port (default 8787)
PORT=8787
